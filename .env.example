# Session signing secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=

# Anthropic (for generating updates)
ANTHROPIC_API_KEY=

# Turso database (hosted SQLite)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Stripe payment link (optional — for upgrade button)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=
